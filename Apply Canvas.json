            "properties": {
              "cnr_id": "comfy-core",
              "ver": "0.24.0",
              "Node name for S&R": "GLSLShader"
            },
            "widgets_values": [
              "#version 300 es\n/* Apply Canvas from Gimp\n   Rebuilt for ComfyUI by AxiomGraph */\n\nprecision highp float;\n\nlayout(location = 0) out vec4 fragColor;\n\nuniform sampler2D u_image0; // Main Color Image\nuniform sampler2D u_image1; // Texture Map (Canvas Weave PNG)\n\nin vec2 v_texCoord;\n\n// Uniforms - Clean separation of types\nuniform float u_float0; // Texture Scale / Size (10.0 to 200.0)\nuniform float u_float1; // Relief Depth / Intensity (0.0 to 5.0)\nuniform int u_int0;     // Light Direction Index (0 to 3)\n\nfloat getHeight(vec2 uv) {\n    vec3 col = texture(u_image1, uv).rgb;\n    return dot(col, vec3(0.299, 0.587, 0.114));\n}\n\nvoid main() {\n    vec2 res0 = vec2(textureSize(u_image0, 0));\n    vec2 res1 = vec2(textureSize(u_image1, 0));\n    vec2 uv = v_texCoord;\n\n    // 1. Precise Aspect Ratio Tiling (With Inverse Scale Fix)\n    float aspect0 = res0.x / res0.y;\n    float aspect1 = res1.x / res1.y;\n    \n    float currentScale = max(u_float0, 1.0);\n    vec2 tileUV = uv * (100.0 / currentScale);\n    tileUV.x *= (aspect0 / aspect1); \n    tileUV = fract(tileUV);\n\n    // 2. High-Pass Emboss Math\n    vec2 texelSize = 1.0 / res1; \n    \n    float hC = getHeight(tileUV);\n    float hR = getHeight(fract(tileUV + vec2(texelSize.x, 0.0)));\n    float hU = getHeight(fract(tileUV + vec2(0.0, texelSize.y)));\n\n    \n    // 3. Discrete Corner Light Selection (Aligned with Custom Combo Index)\n    vec2 lightDir = vec2(1.0, 1.0);\n    \n    if (u_int0 == 0)      lightDir = normalize(vec2( 1.0, -1.0)); // 0: top-right\n    else if (u_int0 == 1) lightDir = normalize(vec2(-1.0, -1.0)); // 1: top-left\n    else if (u_int0 == 2) lightDir = normalize(vec2(-1.0,  1.0)); // 2: bottom-left\n    else if (u_int0 == 3) lightDir = normalize(vec2( 1.0,  1.0)); // 3: bottom-right\n    \n    // Calculate slope along the selected corner vector\n    float slope = (hR - hC) * lightDir.x + (hU - hC) * lightDir.y;\n    float bump = slope * u_float1 * 0.2;\n\n    // 4. Overlay Blend\n    vec3 baseColor = texture(u_image0, uv).rgb;\n    vec3 outputColor = baseColor + vec3(bump);\n\n    fragColor = vec4(clamp(outputColor, 0.0, 1.0), 1.0);\n}",
              "from_input"
            ]
