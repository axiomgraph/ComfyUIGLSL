            "properties": {
              "cnr_id": "comfy-core",
              "ver": "0.24.0",
              "Node name for S&R": "GLSLShader"
            },
            "widgets_values": [
              "/* built from scratch, with some borrowing (rotation) from https://godotshaders.com/shader/rotational-motion-blur-2d/\nbuilt for ComfyUI by axiomgraph\n*/\n\n#version 300 es\nlayout(location = 0) out vec4 fragColor;\nuniform sampler2D u_image0;\n\nin vec2 v_texCoord;\nuniform vec2 u_resolution;\n\n\nuniform int u_int0;\nuniform float u_float0;\nuniform float u_float1;\nuniform float u_float2;\nuniform float u_float3;\n\nfloat aspect = u_resolution.x/u_resolution.y;\n\nvec2 rotate(vec2 uv, vec2 p, float angle)\n{\n    mat2 rotation = mat2(vec2(cos(angle), -sin(angle)),\n                         vec2(sin(angle), cos(angle)));\n    \n    // Scale everything to the aspect-corrected space\n    uv.x *= aspect;\n    \n    // ADJUST PIVOT: Must be scaled to match the new X-axis range\n    vec2 p_scaled = vec2(p.x * aspect, p.y); \n    \n    uv -= p_scaled;\n    uv = uv * rotation;\n    uv += p_scaled;\n    \n    // Scale back to 0.0 - 1.0\n    uv.x *= 1.0 / aspect;\n    return uv;\n}\n\n\n\nvoid main(void)\n{  \n    vec2 uv = v_texCoord;\n    vec4 Color =vec4(0.0);\n    float v;\n   \n    vec2 origin = vec2(u_float1,u_float2) /100.0;\n    \n    \n    for( float i=0.0;i<1.0;i+=1.0/float(u_int0))\n    {\n    \n        v = 0.0+float(i)*0.5*u_float0/100.0;\n        Color += texture(u_image0,rotate(uv,origin, v));  //\n        Color += texture(u_image0,rotate(uv,origin, v/-1.0)); \n    }\n    Color /= float(u_int0*2.0);\n    \n    fragColor =  vec4(Color.rgb*u_float3,Color.a) ;\n}",
              "from_input"
            ]
          },
