              "#version 300 es\n/* Depth of Field Rebuilt for ComfyUI by AxiomGraph */\n\nprecision highp float;\n\nlayout(location = 0) out vec4 fragColor;\n\nuniform sampler2D u_image0; // Main Color Image\nuniform sampler2D u_image1; // Grayscale Depth Map (White=Close, Black=Far)\n\nin vec2 v_texCoord;\n\n// Uniforms - Sequential\nuniform float u_float0; // Max Blur Radius / Lens Size (0.0 to 100.0)\nuniform float u_float1; // Focus Distance / Focal Plane (0.0 to 100.0)\nuniform float u_float2; // Lens Aperture / F-Stop (1.4 to 16.0)\nuniform float u_float3; // Bokeh Highlight Pop / Gamma (1.0 to 4.0)\n\n// Fast, high-frequency integrated screen-space noise\nfloat getNoise(vec2 p) {\n    p = fract(p * vec2(12.9898, 78.233));\n    p += dot(p, p + 19.19);\n    return fract(p.x * p.y);\n}\n\n// 3x3 Neighborhood Filter to smooth out jagged AI depth borders cleanly\nfloat getSmoothedDepth(vec2 uv, vec2 texelSize) {\n    float d = texture(u_image1, uv).r * 0.25;\n    d += texture(u_image1, uv + vec2(texelSize.x, 0.0)).r * 0.125;\n    d += texture(u_image1, uv + vec2(-texelSize.x, 0.0)).r * 0.125;\n    d += texture(u_image1, uv + vec2(0.0, texelSize.y)).r * 0.125;\n    d += texture(u_image1, uv + vec2(0.0, -texelSize.y)).r * 0.125;\n    d += texture(u_image1, uv + vec2(texelSize.x, texelSize.y)).r * 0.0625;\n    d += texture(u_image1, uv + vec2(-texelSize.x, texelSize.y)).r * 0.0625;\n    d += texture(u_image1, uv + vec2(texelSize.x, -texelSize.y)).r * 0.0625;\n    d += texture(u_image1, uv + vec2(-texelSize.x, -texelSize.y)).r * 0.0625;\n    return d;\n}\n\nvoid main() {\n    vec2 res = vec2(textureSize(u_image0, 0));\n    vec2 texelSize = 1.0 / res;\n    \n    float currentDepth = getSmoothedDepth(v_texCoord, texelSize);\n\n    // 1. Convert 0-100 UI value back to a 0.0-1.0 mathematical ratio and invert\n    float normalizedFocus = clamp(u_float1 / 100.0, 0.0, 1.0);\n    float targetDepth = 1.0 - normalizedFocus;\n    \n    // 2. Map u_float2 as a true optical F-Stop. Lower F-number = wider opening = massive blur.\n    float fStop = max(u_float2, 0.5); \n    float blurIntensity = 2.0 / fStop; \n    \n    // Calculate Circle of Confusion (CoC)\n    float coc = abs(currentDepth - targetDepth) * blurIntensity;\n    float radius = clamp(coc * u_float0, 0.0, u_float0);\n\n    // Safety check for perfectly focused elements\n    if (radius < 0.2) {\n        fragColor = texture(u_image0, v_texCoord);\n        return;\n    }\n\n    vec3 accumulatedColor = vec3(0.0);\n    float totalWeight = 0.0;\n\n    float noise_seed = getNoise(v_texCoord * res);\n    const int SAMPLE_COUNT = 64;\n\n    for (int i = 0; i < SAMPLE_COUNT; i++) {\n        // Pure stochastic random disc distribution pattern for flawless film-grain blending\n        float theta = fract(noise_seed + float(i) * 0.381) * 6.2831853; \n        float fraction = sqrt(fract(noise_seed + float(i) * 0.173));\n        float currentRadius = fraction * radius;\n\n        vec2 offset = vec2(cos(theta), sin(theta)) * currentRadius * texelSize;\n        vec2 sampleCoord = clamp(v_texCoord + offset, 0.0, 1.0);\n\n        vec3 sampleColor = texture(u_image0, sampleCoord).rgb;\n        float sampleDepth = getSmoothedDepth(sampleCoord, texelSize);\n\n        // Depth Bleeding Protection: Prevents background from leaking over crisp foreground borders\n        float sampleCoC = abs(sampleDepth - targetDepth) * blurIntensity;\n        float sampleRadius = clamp(sampleCoC * u_float0, 0.0, u_float0);\n        \n        float weight = 1.0;\n        if (sampleDepth > currentDepth && sampleRadius < currentRadius) {\n            weight = 0.05; // Clean down-weighting for background occlusion\n        }\n\n        // Highlight Pop / Gamma Expansion\n        vec3 boostedColor = pow(sampleColor, vec3(u_float3));\n        accumulatedColor += boostedColor * weight;\n        totalWeight += weight;\n    }\n\n    // Average the accumulated values and reverse the gamma scaling\n    vec3 finalColor = accumulatedColor / (totalWeight + 0.000001);\n    finalColor = pow(finalColor, vec3(1.0 / u_float3));\n\n    fragColor = vec4(clamp(finalColor, 0.0, 1.0), texture(u_image0, v_texCoord).a);\n}",
