              "Node name for S&R": "GLSLShader"
            },
            "widgets_values": [
              "#version 300 es\n/* High-Radius Cinematic Lens Blur (Stochastic Optimization)\n   Rebuilt for ComfyUI by AxiomGraph */\n\nprecision highp float;\n\nlayout(location = 0) out vec4 fragColor;\nuniform sampler2D u_image0;\nin vec2 v_texCoord;\n\n// Uniforms - Sequential\nuniform float u_float0; // Blur Radius (0.0 to 60.0)\nuniform float u_float1; // Bokeh Highlight Pop / Gamma (1.0 to 4.0)\n\n// High-frequency screen-space noise function\nfloat getNoise(vec2 p) {\n    return fract(sin(dot(p, vec2(12.9898, 78.233))) * 43758.5453123);\n}\n\nvoid main() {\n    vec2 res = vec2(textureSize(u_image0, 0));\n    vec2 texelSize = 1.0 / res;\n    float radius = max(u_float0, 0.0);\n    \n    // Safety check for zero radius\n    if (radius < 0.5) {\n        fragColor = texture(u_image0, v_texCoord);\n        return;\n    }\n\n    vec3 accumulatedColor = vec3(0.0);\n    float totalWeight = 0.0;\n\n    #define PI 3.14159265359\n    #define GOLDEN_ANGLE 2.39996323 // Perfect Vogel distribution constant\n\n    // Calculate a unique noise value for this specific screen pixel\n    float dither = getNoise(v_texCoord * res);\n\n    // 64 samples is the absolute sweet spot for massive blurs on the GPU\n    const int SAMPLE_COUNT = 64;\n\n    for (int i = 0; i < SAMPLE_COUNT; i++) {\n        // Jitter the sample step to eliminate concentric ring artifacts\n        float fraction = (float(i) + dither) / float(SAMPLE_COUNT);\n        \n        // Vogel Spiral distribution: Square root ensures perfectly even area density\n        float currentRadius = sqrt(fraction) * radius;\n        \n        // Jitter the rotation angle to break up directional alignment streaks\n        float theta = float(i) * GOLDEN_ANGLE + (dither * 2.0 * PI);\n\n        vec2 offset = vec2(cos(theta), sin(theta)) * currentRadius * texelSize;\n        vec3 sampleColor = texture(u_image0, v_texCoord + offset).rgb;\n\n        // Gamma boost amplifies background lights into crisp bokeh disks\n        vec3 boostedColor = pow(sampleColor, vec3(u_float1));\n\n        accumulatedColor += boostedColor;\n        totalWeight += 1.0;\n    }\n\n    // Average and reverse the gamma curve to restore exposure balance\n    vec3 finalColor = accumulatedColor / totalWeight;\n    finalColor = pow(finalColor, vec3(1.0 / u_float1));\n\n    // Retain the clean alpha channel from the original generation\n    float alpha = texture(u_image0, v_texCoord).a;\n\n    fragColor = vec4(clamp(finalColor, 0.0, 1.0), alpha);\n}",
              "from_input"
            ]
