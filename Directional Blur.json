            "properties": {
              "cnr_id": "comfy-core",
              "ver": "0.24.0",
              "Node name for S&R": "GLSLShader"
            },
            "widgets_values": [
              "/* GLSL Shader For ComfyUI Built by Axiomgraph */\n#version 300 es\nprecision highp float;\n\nlayout(location = 0) out vec4 fragColor;\n\nuniform sampler2D u_image0;\nin vec2 v_texCoord;\n\nuniform int u_int0;     // Quality (1-50)\nuniform float u_float0; // Gain (normally 1.0)\nuniform float u_float1; // Angle (degrees)\nuniform float u_float2; // Blur Radius (pixels)\n\nvoid main()\n{\n    vec2 uv = v_texCoord;\n\n    // Direction\n    float angle = radians(u_float1);\n    vec2 dir = vec2(cos(angle), sin(angle));\n\n    // Convert pixel radius to UV units\n    vec2 texelSize = 1.0 / vec2(textureSize(u_image0, 0));\n    vec2 blurDir = dir * texelSize * u_float2;\n\n    // Noise for banding reduction\n    float noise = fract(\n        sin(dot(uv, vec2(12.9898, 78.233))) *\n        43758.5453\n    );\n\n    vec3 color = vec3(0.0);\n    float ws = 0.0;\n\n    int quality = clamp(u_int0, 1, 50);\n\n    for (int i = -50; i <= 50; i++)\n    {\n        if (abs(i) > quality)\n            continue;\n\n        float p = (float(i) + noise - 0.5) / float(quality);\n\n        // Triangular weight\n        float w = 1.0 - abs(p);\n\n        vec2 offset = blurDir * p;\n\n        color += texture(u_image0, uv + offset).rgb * w;\n        ws += w;\n    }\n\n    color /= max(ws, 0.00001);\n\n    // Optional gain\n    color *= max(u_float0, 0.0);\n\n    fragColor = vec4(color, 1.0);\n}",
              "from_input"
            ]
