            "properties": {
              "cnr_id": "comfy-core",
              "ver": "0.24.0",
              "Node name for S&R": "GLSLShader"
            },
            "widgets_values": [
              "/* Classic Halftone Filter for ComfyUI by AxiomGraph */\n   \n#version 300 es\nprecision highp float;\n\nlayout(location = 0) out vec4 fragColor;\nuniform sampler2D u_image0;\nin vec2 v_texCoord;\n\n// Uniforms\nuniform float u_float0; // Dot Size (pixels, e.g., 5.0 to 30.0)\nuniform float u_float1; // Grid Angle (degrees, 45.0 is the print standard)\nuniform float u_float2; // Dot Sharpness/Feather (1.0 is sharp, 3.0 is soft)\n\nvoid main(void)\n{\n    vec2 res = vec2(textureSize(u_image0, 0));\n    vec2 uv = v_texCoord;\n\n    // 1. Setup rotation matrices\n    float angle = radians(u_float1);\n    float s = sin(angle);\n    float c = cos(angle);\n    mat2 rot = mat2(c, -s, s, c);\n    mat2 invRot = mat2(c, s, -s, c); // We need the inverse to sample the image later\n\n    // 2. Convert to pixel space and rotate the canvas\n    vec2 pixelPos = uv * res;\n    vec2 rotPos = rot * pixelPos;\n\n    // 3. Grid Snapping\n    float dotSize = max(u_float0, 2.0); // Safety limit\n    vec2 gridPos = mod(rotPos, dotSize);\n    vec2 cellCenter = rotPos - gridPos + vec2(dotSize * 0.5);\n\n    // 4. THE PRO TRICK: Inverse Sampling\n    // Because we rotated the grid, we have to un-rotate the center coordinate \n    // to find out what pixel to sample from the original flat image.\n    vec2 sampleUv = (invRot * cellCenter) / res;\n    vec3 centerColor = texture(u_image0, sampleUv).rgb;\n\n    // 5. Calculate true Luminance (Brightness)\n    float lum = dot(centerColor, vec3(0.299, 0.587, 0.114));\n\n    // 6. THE OTHER PRO TRICK: Area vs. Radius\n    // We use sqrt() so the physical AREA of the dot scales linearly with darkness.\n    // Multiplying by 0.707 (sqrt(2)/2) ensures the dots are allowed to grow large \n    // enough to touch corner-to-corner, creating pure black areas.\n    float maxRadius = dotSize * 0.707;\n    float radius = maxRadius * sqrt(1.0 - lum);\n\n    // 7. Draw the dot\n    float dist = distance(gridPos, vec2(dotSize * 0.5));\n    float sharpness = max(u_float2, 0.5); // Feathering for anti-aliasing\n    \n    // smoothstep creates the anti-aliased edge of the circle\n    float dotMask = smoothstep(radius, radius - sharpness, dist);\n\n    // Output pure black dots on a white background\n    fragColor = vec4(vec3(dotMask), 1.0);\n}",
              "from_input"
            ]
