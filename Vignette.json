              "Node name for S&R": "GLSLShader"
            },
            "widgets_values": [
              "/* Adapted from olive video editor project \nRebuilt for ComfyUI by axiomgraph */\n\n#version 300 es\n#define M_PI 3.1415926535897932384626433832795\nprecision highp float;\n\nlayout(location = 0) out vec4 fragColor;\n\nuniform sampler2D u_image0;\n\nin vec2 v_texCoord;\nuniform vec2 u_resolution;\n\nuniform float u_float0; // Radius (0-100+)\nuniform float u_float1; // Softness / Feather (0-100+)\nuniform float u_float2; // Origin X Offset (-50 to 50, 0 is center)\nuniform float u_float3; // Origin Y Offset (-50 to 50, 0 is center)\nuniform bool u_bool0;   // Aspect Ratio Correction\n\nuniform int invert;\n\nvoid main(void) {\n    vec2 radiusSoftness = vec2(u_float0, u_float1);\n    vec2 centerOffset = vec2(u_float2, u_float3);\n    \n    // Prevent zero-radius glitching\n    if (radiusSoftness.x <= 0.0) {\n        discard;\n    }\n    \n    vec4 c = texture(u_image0, v_texCoord);\n    vec2 vignetteCoord = v_texCoord;\n    \n    // Aspect ratio correction (keeps the vignette perfectly circular)\n    if (u_bool0) {\n        float ar = (u_resolution.x / u_resolution.y);\n        vignetteCoord.x *= ar;\n        vignetteCoord.x -= (1.0 - (1.0 / ar)) * 0.5; // Fixed centering for AR\n    }\n    \n    // Base distance from center\n    float dist = distance(vignetteCoord, vec2(0.5 + centerOffset.x * 0.01, 0.5 + centerOffset.y * 0.01));\n    \n    // Convert 0-100 inputs to 0.0-1.0 UV space\n    float radius = radiusSoftness.x * 0.01;\n    float softness = radiusSoftness.y * 0.01;\n    \n    // Calculate the smooth gradient\n    // Outer edge is 'radius', inner edge is 'radius - softness'\n    float vignetteMask = smoothstep(radius, radius - softness, dist);\n    \n    if (bool(invert)) {\n        c.rgb *= (1.0 - vignetteMask);\n    } else {\n        c.rgb *= vignetteMask;\n    }\n    \n    fragColor = c;\n}",
              "from_input"
            ]
