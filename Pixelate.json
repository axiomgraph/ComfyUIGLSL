              "Node name for S&R": "GLSLShader"
            },
            "widgets_values": [
              "/* Pixelate Filter Adapted from natron plugins\n   Rebuilt for ComfyUI by AxiomGraph */\n\n#version 300 es\nprecision highp float;\n\nlayout(location = 0) out vec4 fragColor;\nuniform sampler2D u_image0;\nin vec2 v_texCoord;\n\n// Uniforms\nuniform float u_float0; // Block Size (in pixels)\n\nvoid main(void)\n{\n    vec2 uv = v_texCoord;\n    \n    // Safety check: block size cannot be less than 1 pixel, otherwise mod() crashes\n    float blockSize = max(u_float0, 1.0);\n    \n    // Get true image resolution to automatically handle aspect ratio\n    vec2 res = vec2(textureSize(u_image0, 0));\n    \n    // Convert the block size from physical pixels to 0.0-1.0 UV space\n    vec2 size = blockSize / res;\n    \n    // Snap UV coordinates to the grid. \n    // Adding (size * 0.5) ensures we sample the exact center of the block for the cleanest color.\n    vec2 pix_uv = uv - mod(uv, size) + (size * 0.5);\n    \n    fragColor = texture(u_image0, pix_uv);\n}",
              "from_input"
            ]
